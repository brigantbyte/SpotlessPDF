    "app.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "حمّل ملف PDF وأزل الإعلانات واحفظه تلقائيًا في مجلد التنزيلات أو في الموقع الذي تختاره."
          }
        },
        "br": {
          "stringUnit": {
            "state": "translated",
            "value": "Karg ur PDF, lam kuit arzhioù-bruderezh ha mir anezhañ ent emgefreek en teuliad Pellgargadennoù pe el lec'hiadur a zibabez."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Načti PDF, odstraň reklamy a automaticky ho ulož do složky Stahování nebo do umístění, které si zvolíš."
          }
        },
        "cy": {
          "stringUnit": {
            "state": "translated",
            "value": "Llwytha PDF, tynnu hysbysebion a'i chadw'n awtomatig yn y ffolder Lawrlwythiadau neu yn y lleoliad o dy ddewis."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indlæs en PDF, fjern annoncer, og gem den automatisk i mappen Overførsler eller på den placering, du vælger."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Lade ein PDF, entferne Werbung und speichere es automatisch in deinem Downloads-Ordner oder an einem Ort deiner Wahl."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Φόρτωσε ένα PDF, αφαίρεσε διαφημίσεις και αποθήκευσέ το αυτόματα στον φάκελο Λήψεις ή στη θέση που θα επιλέξεις."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Load a PDF, remove ads and save it automatically to your downloads folder or to the location you choose."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Carga un PDF, elimina anuncios y guárdalo automáticamente en tu carpeta de descargas o en la ubicación que elijas."
          }
        },
        "et": {
          "stringUnit": {
            "state": "translated",
            "value": "Laadi PDF, eemalda reklaamid ja salvesta see automaatselt allalaadimiste kausta või valitud asukohta."
          }
        },
        "fa": {
          "stringUnit": {
            "state": "translated",
            "value": "یک PDF بارگذاری کنید، تبلیغات را حذف کنید و آن را به صورت خودکار در پوشه دانلودها یا مکانی که انتخاب می‌کنید ذخیره کنید."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lataa PDF, poista mainokset ja tallenna se automaattisesti Lataukset-kansioon tai valitsemaasi sijaintiin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Chargez un PDF, supprimez les publicités et enregistrez-le automatiquement dans votre dossier Téléchargements ou à l’emplacement de votre choix."
          }
        },
        "ga": {
          "stringUnit": {
            "state": "translated",
            "value": "Lódáil PDF, bain fógraí de agus sábháil go huathoibríoch é chuig d’fhillteán íoslódálacha nó chuig an suíomh a roghnaíonn tú."
          }
        },
        "gd": {
          "stringUnit": {
            "state": "translated",
            "value": "Luchdaich PDF, thoir air falbh sanasan agus sàbhail e gu fèin-obrachail dhan phasgan luchdaidhean a-nuas no dhan àite a thaghas tu."
          }
        },
        "gl": {
          "stringUnit": {
            "state": "translated",
            "value": "Carga un PDF, elimina anuncios e gárdao automaticamente na carpeta de descargas ou noutra localización que escollas."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "טען קובץ PDF, הסר פרסומות ושמור אותו אוטומטית בתיקיית ההורדות או במיקום שתבחר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक PDF लोड करें, विज्ञापन हटाएँ और उसे अपने डाउनलोड फ़ोल्डर या चुनी गई जगह पर अपने आप सहेजें।"
          }
        },
        "hr": {
          "stringUnit": {
            "state": "translated",
            "value": "Učitaj PDF, ukloni oglase i automatski ga spremi u mapu Preuzimanja ili na lokaciju koju odabereš."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Carica un PDF, rimuovi gli annunci e salvalo automaticamente nella cartella Download o nella posizione che scegli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PDFを読み込み、広告を削除して、ダウンロードフォルダまたは選択した場所に自動保存します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PDF를 불러오고 광고를 제거한 뒤 다운로드 폴더나 선택한 위치에 자동으로 저장합니다."
          }
        },
        "kw": {
          "stringUnit": {
            "state": "translated",
            "value": "Karga PDF, lemel dhiworth ar bruderezh ha y fiyans yn awtomatek dhe'th arghans pellgarga po dhe'n le mayth eus dewisedh."
          }
        },
        "lt": {
          "stringUnit": {
            "state": "translated",
            "value": "Įkelk PDF, pašalink reklamas ir automatiškai išsaugok jį į Atsisiuntimų aplanką arba pasirinktą vietą."
          }
        },
        "lv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ielādē PDF, noņem reklāmas un automātiski saglabā to mapē Lejupielādes vai izvēlētajā vietā."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Last inn en PDF, fjern annonser og lagre den automatisk i Nedlastinger-mappen eller på stedet du velger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Laad een PDF, verwijder advertenties en sla deze automatisch op in je Downloads-map of op de locatie die je kiest."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wczytaj plik PDF, usuń reklamy i zapisz go automatycznie w folderze Pobrane lub w wybranej lokalizacji."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Carrega um PDF, remove anúncios e guarda-o automaticamente na pasta Descargas ou na localização que escolheres."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Încarcă un PDF, elimină reclamele și salvează-l automat în dosarul Descărcări sau în locația aleasă."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ladda in en PDF, ta bort annonser och spara den automatiskt i mappen Hämtade filer eller på platsen du väljer."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Завантаж PDF, прибери рекламу та автоматично збережи його в теку Завантаження або в обране місце."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "加载 PDF，移除广告，并自动将其保存到“下载”文件夹或你选择的位置。"
          }
        }
      }
    },
